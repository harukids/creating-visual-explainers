# OpenAI API key（サーバー側のみ — ブラウザには出さない）
OPENAI_API_KEY=sk-...

# Slack通知先（Incoming Webhook URL）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 任意：フォームが空のときだけサーバー側の「いつもの」文脈を使う（自分専用デプロイ向け）
# DEFAULT_AUDIENCE=30代女性・美容と予防医療に関心があり…
# DEFAULT_WORK_CONTEXT=MC・美容健康・Nu Skin・AI活用を横断。信頼と世界観共感を重視し…

# 任意：この環境変数をセットすると、コード内の既定ブランド説明を丸ごと置き換え（長文・改行可）
# BRAND_GUIDELINES=...

# 任意：設定すると /api/generate に Authorization: Bearer <同じ値> が必須（Cron は自動で付与）
# GENERATE_SECRET=

# 任意：Cron の DAILY_IMAGE_URL のホストをカンマ区切りで限定（例: cdn.supabase.co,yourdomain.com）
# DAILY_IMAGE_ALLOWED_HOSTS=

# --- 毎日Cron（api/cron-daily）用 ---
# CRON_SECRET=ランダムな長い文字列（VercelのCronと一致させる）
# DAILY_IMAGE_URL=https://...   または
# DAILY_IMAGE_SUMMARY=テキスト要約のみのとき
# CRON_AUDIENCE=
# CRON_WORK_CONTEXT=
# CRON_NG_WORDS=
# CRON_VARIATION_HINT=
